generator client {
	provider = "prisma-client"
	output   = "../../src/generated/prisma"
	runtime  = "nodejs"
}

datasource db {
	provider = "postgresql"
}

model User {
	id         String @id @default(uuid())
	username   String @unique
	email      String @unique
	createdAt  String
	credential String

	gitTokens          GitToken[]
	orgMemberships     OrganizationMember[]
	repoGrants         RepositoryMember[]
	prComments         PullRequestComment[]
	ownedOrganizations Organization[]       @relation("OrgOwner")
	ownedRepositories  Repository[]         @relation("RepoOwner")
	userRepositories   Repository[]         @relation("UserRepositoryNamespace")
	pullRequests       PullRequest[]

	@@index([username])
	@@index([email])
}

model GitToken {
	id         String @id @default(uuid())
	userId     String
	name       String
	createdAt  String
	secretHash String
	user       User   @relation(fields: [userId], references: [id], onDelete: Cascade)

	@@index([userId])
}

model Organization {
	name        String  @id
	description String?
	createdAt   String
	ownerId     String?

	owner        User?                @relation("OrgOwner", fields: [ownerId], references: [id])
	members      OrganizationMember[]
	repositories Repository[]
	taskBoards   TaskBoard[]

	@@index([ownerId])
}

model OrganizationMember {
	organizationName String
	userId           String
	role             String
	createdAt        String

	organization Organization @relation(fields: [organizationName], references: [name], onDelete: Cascade)
	user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

	@@id([organizationName, userId])
	@@index([userId])
}

model Repository {
	id               String  @id @default(uuid())
	organizationName String?
	userId           String?
	name             String
	description      String?
	createdAt        String
	ownerId          String

	organization Organization?      @relation(fields: [organizationName], references: [name], onDelete: Cascade)
	user         User?              @relation("UserRepositoryNamespace", fields: [userId], references: [id], onDelete: Cascade)
	owner        User               @relation("RepoOwner", fields: [ownerId], references: [id])
	members      RepositoryMember[]
	pullRequests PullRequest[]

	@@index([organizationName])
	@@index([userId])
}

model RepositoryMember {
	repositoryId String
	userId       String
	role         String
	createdAt    String
	updatedAt    String

	repository Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
	user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

	@@id([repositoryId, userId])
	@@index([userId])
}

model PullRequest {
	repositoryId   String
	prNumber       Int
	title          String
	sourceBranch   String
	targetBranch   String
	status         String
	mergeCommitSha String?
	authorName     String
	authorId       String?
	createdAt      String
	updatedAt      String
	viewedFiles    String  @default("[]")

	repository Repository           @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
	author     User?                @relation(fields: [authorId], references: [id])
	comments   PullRequestComment[]

	@@id([repositoryId, prNumber])
	@@index([repositoryId, status])
}

model PullRequestComment {
	id             String @id @default(uuid())
	repositoryId   String
	prNumber       Int
	targetType     String
	targetFilePath String
	body           String
	authorId       String
	authorName     String
	createdAt      String

	pullRequest PullRequest @relation(fields: [repositoryId, prNumber], references: [repositoryId, prNumber], onDelete: Cascade)
	author      User        @relation(fields: [authorId], references: [id])

	@@index([repositoryId, prNumber])
	@@index([authorId])
}

model PullRequestCounter {
	repositoryId String @id
	lastNumber   Int    @default(0)

	@@index([repositoryId])
}

model TaskBoard {
	id               String  @id @default(uuid())
	organizationName String
	key              String
	name             String
	description      String?
	lastTaskNumber   Int     @default(0)
	createdAt        String
	updatedAt        String

	organization Organization @relation(fields: [organizationName], references: [name], onDelete: Cascade)
	columns      TaskColumn[]

	@@unique([organizationName, key])
	@@index([organizationName])
}

model TaskColumn {
	id        String @id @default(uuid())
	boardId   String
	name      String
	position  Int
	createdAt String
	updatedAt String

	board TaskBoard  @relation(fields: [boardId], references: [id], onDelete: Cascade)
	cards TaskCard[]

	@@index([boardId, position])
}

model TaskCard {
	id          String @id @default(uuid())
	boardId     String
	columnId    String
	publicId    String
	number      Int
	title       String
	description String
	position    Int
	createdAt   String
	updatedAt   String

	column TaskColumn @relation(fields: [columnId], references: [id], onDelete: Cascade)

	@@unique([boardId, number])
	@@unique([boardId, publicId])
	@@index([columnId, position])
}
