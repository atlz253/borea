{
  "name": "nirvana",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "prisma generate && vite dev --port 3000",
    "generate-routes": "tsr generate",
    "build": "prisma generate && vite build",
    "start": "node .output/server/index.mjs",
    "preview": "vite preview",
    "test": "vitest run",
		"test:coverage": "vitest run --coverage",
		"test:integration": "vitest run --config vitest.integration.config.ts",
		"format": "biome format",
		"format:fix": "biome format --write",
		"lint": "biome lint",
		"lint:fix": "biome lint --write --unsafe",
		"check": "biome check",
		"check:fix": "biome check --write --unsafe",
    "typecheck": "tsc --noEmit",
    "test:e2e": "playwright test && playwright test --config playwright.organizations.config.ts && playwright test --config playwright.auth.config.ts",
    "test:e2e:organizations": "playwright test --config playwright.organizations.config.ts",
    "test:e2e:auth": "playwright test --config playwright.auth.config.ts",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:install": "playwright install",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^8.5.0",
    "@libsql/client": "^0.15.15",
    "@mantine/code-highlight": "^9.4.1",
    "@mantine/core": "^9.4.1",
    "@mantine/hooks": "^9.4.1",
    "@mantine/notifications": "^9.4.1",
    "@prisma/adapter-libsql": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@tanstack/react-devtools": "latest",
    "@tanstack/react-router": "latest",
    "@tanstack/react-router-devtools": "latest",
    "@tanstack/react-router-ssr-query": "latest",
    "@tanstack/react-start": "latest",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/router-plugin": "^1.132.0",
    "execa": "^9.6.1",
    "highlight.js": "^11.11.1",
    "lucide-react": "^0.545.0",
    "nitro": "npm:nitro-nightly@latest",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.5",
    "@playwright/test": "^1.61.1",
    "@tanstack/devtools-vite": "latest",
    "@tanstack/router-cli": "^1.132.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vercel/nft": "1.10.2",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.9",
    "jsdom": "^28.1.0",
    "nf3": "0.3.19",
    "prisma": "^7.8.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.0",
    "vitest": "^4.1.5"
  },
  "overrides": {
    "unicorn-magic": "0.4.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss"
    ]
  }
}
