{
	"$schema": "https://biomejs.dev/schemas/2.4.5/schema.json",
	"vcs": {
		"enabled": false,
		"clientKind": "git",
		"useIgnoreFile": false
	},
	"files": {
		"ignoreUnknown": false,
		"includes": [
			"**/src/**/*",
			"**/.vscode/**/*",
			"**/index.html",
			"**/vite.config.ts",
			"**/vitest.config.ts",
			"**/tests/**/*",
			"**/playwright.config.ts",
			"!**/src/routeTree.gen.ts",
			"!**/src/styles.css",
			"!**/coverage",
			"!**/playwright-report",
			"!**/playwright-report-*"
		]
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab"
	},
	"assist": { "actions": { "source": { "organizeImports": "on" } } },
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"nursery": {
				"noExcessiveLinesPerFile": {
					"level": "error",
					"options": { "maxLines": 600 }
				},
				"noFloatingPromises": "error"
			},
			"complexity": {
				"noExcessiveCognitiveComplexity": "error"
			},
			"correctness": {
				"useExhaustiveDependencies": "error"
			},
			"suspicious": {
				"noConsole": "error",
				"noConfusingVoidType": "error",
				"noEmptyInterface": "error"
			},
			"style": {
				"noMagicNumbers": "error",
				"noRestrictedImports": {
					"level": "error",
					"options": {
						"patterns": [
							{
								"group": [
									"#/modules/*/**",
									"@/modules/*/**",
									"**/modules/*/**"
								],
								"message": "Deep imports into domain modules are forbidden. Import only from the module barrel: #/modules/<name>. See ADR 0003."
							}
						]
					}
				}
			}
		}
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "double"
		}
	},
	"overrides": [
		{
			"includes": [
				"**/*.test.ts",
				"**/*.test.tsx",
				"**/*.spec.ts",
				"**/*.spec.tsx",
				"**/tests/e2e/**"
			],
			"linter": {
				"rules": {
					"nursery": {
						"noExcessiveLinesPerFile": {
							"level": "error",
							"options": { "maxLines": 850 }
						},
						"noFloatingPromises": "warn"
					},
					"complexity": {
						"noExcessiveCognitiveComplexity": "warn"
					},
					"suspicious": {
						"noConsole": "warn"
					},
					"style": {
						"noMagicNumbers": "off",
						"noRestrictedImports": "off"
					}
				}
			}
		}
	]
}
